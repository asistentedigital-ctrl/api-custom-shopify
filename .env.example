# Puerto en el que escucha el servidor (Render lo inyecta automáticamente en producción)
PORT=3000

# Clave que Kommo debe enviar en el header "X-API-KEY" en cada request al webhook.
# Génerala tú mismo (ej: openssl rand -hex 32) y configúrala igual en el paso "Webhook" del Salesbot.
KOMMO_API_KEY=changeme

# Credenciales de la tienda Shopify.
# Dominio interno de la tienda (el .myshopify.com, no el dominio público)
SHOPIFY_STORE_DOMAIN=mi-tienda.myshopify.com

# App creada en el Dev Dashboard (dev.shopify.com): Client ID y Client Secret.
# El API los intercambia automáticamente por un access token (client credentials grant).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Solo si usas una app personalizada heredada con token estático (shpat_...).
# Si está definido, tiene prioridad sobre CLIENT_ID/CLIENT_SECRET.
SHOPIFY_ADMIN_ACCESS_TOKEN=

SHOPIFY_API_VERSION=2026-07

# Para que el API escriba la respuesta en un campo del lead (flujo Salesbot
# "Enviar webhook"). Token de larga duración de una integración privada de Kommo.
KOMMO_SUBDOMAIN=miempresa.kommo.com
KOMMO_ACCESS_TOKEN=
# IDs de los campos personalizados del lead (GET /api/v4/leads/custom_fields)
KOMMO_QUERY_FIELD_ID=
KOMMO_RESPONSE_FIELD_ID=
